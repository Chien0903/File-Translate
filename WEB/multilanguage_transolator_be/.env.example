# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Bắt buộc đổi JWT_SECRET_KEY trong production (dùng giá trị random, dài >= 50 ký tự)
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite cho local/dev (mặc định khi DEBUG=True)
USE_SQLITE=True
# PostgreSQL cho production — đặt USE_SQLITE=False và điền đầy đủ bên dưới
DB_HOST=
DB_PORT=
DB_USER=
DB_NAME=
DB_PASSWORD=

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
PROJECT_ID=
INPUT_URI=gs://bucket-name/glossary_term.csv
BUCKET_NAME=

# ─── Azure ────────────────────────────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Convert API ──────────────────────────────────────────────────────────────
CONVERTAPI_API_CREDENTIALS=

# ─── CORS ─────────────────────────────────────────────────────────────────────
PRODUCTION_URL=https://your-production-url.com
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ALL=False
